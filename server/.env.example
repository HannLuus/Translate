# Google Cloud: path to service account JSON (required for Speech-to-Text and Text-to-Speech)
# For local: use a file path. For Supabase Edge Functions: set GOOGLE_APPLICATION_CREDENTIALS_JSON in Supabase secrets.
GOOGLE_APPLICATION_CREDENTIALS=./path-to-your-service-account.json
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}  # optional; used when no file (e.g. local .env)

# Optional: override project ID (otherwise read from the JSON key file)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Gemini API key (required for translation)
GEMINI_API_KEY=your-gemini-api-key

# Optional: server port (default 3001)
# PORT=3001
